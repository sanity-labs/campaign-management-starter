{
  "name": "campaign-orchestration-starter",
  "version": "1.0.0",
  "private": true,
  "description": "Sanity use case starter for campaign management and orchestration.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n studio,frontend -c \"#f03e2f,#8b5cf6\" \"pnpm --filter studio dev\" \"pnpm --filter @starter/frontend dev\"",
    "build": "pnpm -r --if-present build",
    "bootstrap": "pnpm --filter studio bootstrap",
    "test": "pnpm -r --if-present test",
    "lint": "eslint --cache --cache-location node_modules/.cache/eslint/ .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typegen": "pnpm --filter studio typegen",
    "pretypecheck": "pnpm run typegen",
    "typecheck": "pnpm -r --if-present typecheck",
    "validate": "sanity-template-validate"
  },
  "dependencies": {
    "@sanity/functions": "^1.2.1"
  },
  "devDependencies": {
    "@sanity/blueprints": "0.13.1",
    "@sanity/client": "catalog:",
    "@sanity/template-validator": "^3.0.0",
    "@starter/eslint-config": "workspace:*",
    "@types/node": "^22.19.13",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.3",
    "groq": "catalog:",
    "oxfmt": "^0.41.0",
    "sanity": "catalog:",
    "tsx": "^4.21.0"
  },
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "packageManager": "pnpm@10.30.3"
}
